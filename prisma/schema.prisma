generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients  Client[]
  sessions ServiceSession[]
}

model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  blvdId    String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId   String
  user     User             @relation(fields: [userId], references: [id])
  sessions ServiceSession[]

  @@index([userId])
  @@index([blvdId])
}

model ServiceSession {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id])
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  formulas Formula[]
  photos   Photo[]

  @@index([clientId])
  @@index([userId])
}

model Formula {
  id            String  @id @default(cuid())
  name          String
  developer     String?
  ratio         String?
  processingMin Int?
  notes         String?

  sessionId String
  session   ServiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  components FormulaComponent[]

  @@index([sessionId])
}

model FormulaComponent {
  id      String @id @default(cuid())
  product String
  amount  Float
  unit    String @default("oz")

  formulaId String
  formula   Formula @relation(fields: [formulaId], references: [id], onDelete: Cascade)

  @@index([formulaId])
}

model Photo {
  id        String   @id @default(cuid())
  url       String
  angle     String?
  timing    String?
  lighting  String?
  createdAt DateTime @default(now())

  sessionId String
  session   ServiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}
